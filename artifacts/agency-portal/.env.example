# Copia in .env (non committare) o imposta le stesse chiavi su Vercel (Production).

# Login Supabase nel browser (da Project Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Chiave anon o “publishable” dalla dashboard (stesso ruolo lato client)
VITE_SUPABASE_ANON_KEY=
# oppure, se la dashboard mostra solo publishable:
# VITE_SUPABASE_PUBLISHABLE_KEY=

# true = login obbligatorio; assente/false = portale senza auth (demo)
# VITE_AUTH_ENABLED=true

# Solo sviluppo locale: dove gira l’api-server (proxy Vite /api → questo host)
# VITE_API_PROXY_TARGET=http://localhost:8080
