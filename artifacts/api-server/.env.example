# Copia in .env (non committare) o imposta su Render.

# Obbligatorio: stesso Postgres del progetto Supabase (Connection string)
# Allineare lo schema (tabelle/colonne) al codice: dalla root del monorepo,
#   export DATABASE_URL='postgresql://...' && pnpm run db:push
DATABASE_URL=postgresql://...

# Verifica JWT inviato dal portale (Project Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=

# URL progetto + chiave anon/publishable: servono a GET /api/public/supabase-config
# (così il browser può inizializzare Supabase senza VITE_* nel build del front)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
# oppure: PUBLIC_SUPABASE_URL / PUBLIC_SUPABASE_ANON_KEY
# oppure nomi publishable: SUPABASE_PUBLISHABLE_KEY / PUBLIC_SUPABASE_PUBLISHABLE_KEY

# CORS: origini del portale (virgola se più di una)
FRONTEND_URLS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# Admin: UUID utente da Supabase (Authentication → Users), separati da virgola
# ADMIN_SUPABASE_USER_IDS=
# Opzionale (stesso effetto, nome legacy): ADMIN_CLERK_USER_IDS= oppure ADMIN_AUTH_USER_IDS=

# Solo demo: non usare in produzione con dati reali
# SICUREZZA: tenere sempre false in produzione
API_AUTH_DISABLED=false
# Id sintetico in bypass (default __api_anonymous__): API_ANONYMOUS_USER_ID=
# Legacy: API_ANONYMOUS_CLERK_USER_ID=

# Genera con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=
TOKEN_ENCRYPTION_KEY_VERSION=1

# Inviti email team (opzionale)
# SUPABASE_SERVICE_ROLE_KEY=
# PORTAL_PUBLIC_URL=https://tuo-portale.vercel.app

# Google Drive cloud backup (opzionale)
# Attiva copia automatica dei file caricati nel portale su Google Drive
# GOOGLE_DRIVE_SYNC_ENABLED=true
# GOOGLE_DRIVE_ROOT_FOLDER_ID=xxxxxxxxxxxxxxxxxxxx
# GOOGLE_DRIVE_SYNC_SECTIONS=files
# GOOGLE_DRIVE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
# GOOGLE_DRIVE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Anthropic (Caption AI tool)
# ANTHROPIC_API_KEY=sk-ant-...

PORT=8080
